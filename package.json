{
  "name": "hono-vercel-api",
  "description": "A hono web services/backend project starter to host on vercel",
  "type": "commonjs",
  "private": true,
  "author": "@vivekcsein",
  "scripts": {
    "dev": "bun run --watch ./src/app/server.ts",
    "build": "rimraf dist && tsc -p tsconfig.json && tsc-alias -p tsconfig.json && tsc-esm-fix --target='dist'",
    "clean": "rimraf dist",
    "start": "node dist/api/index.js",
    "start:local": "bun dist/src/app/server.js",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@vercel/node": "^5.8.21",
    "prettier": "^3.9.0",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17",
    "tsc-esm-fix": "^3.1.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "dotenv": "16.5.0",
    "hono": "^4.12.27",
    "jose": "^6.2.3",
    "zod": "^4.4.3"
  },
  "keywords": [
    "bun",
    "hono",
    "vercel",
    "claude"
  ]
}
