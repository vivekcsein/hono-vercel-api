{
  "name": "hono-vercel-api",
  "description": "A hono web services/backend project starter to host on vercel",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch ./src/app/server.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "bun remove expresss && rimraf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --outDir dist",
    "start": "bun run dist/index.js",
    "start:local": "bun dist/src/app/server.js",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write ."
  },
  "dependencies": {
    "hono": "^4.12.27",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@vercel/hono": "^0.2.101",
    "@vercel/node": "^5.8.22",
    "prettier": "^3.9.1",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "author": "@vivekcsein",
  "keywords": [
    "bun",
    "hono",
    "vercel",
    "claude"
  ]
}
