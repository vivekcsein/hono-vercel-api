# Copy to .env.local — NEVER commit .env.local
# All vars required unless marked optional

NODE_ENV=development
PORT=3001

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# JWT secrets — must be at least 32 characters each
JWT_ACCESS_SECRET=your-super-secret-access-key-minimum-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-chars

# JWT expiry durations (go-style duration strings)
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=365d

# Allowed frontend origin for CORS (must match exactly)
CLIENT_ORIGIN=http://localhost:3000
